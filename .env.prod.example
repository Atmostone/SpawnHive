# Production/demo environment for SpawnHive (SPA-78).
# Copy to `.env` on the server and fill in real values. NEVER commit the filled-in .env
# (`.env` and `.env.prod` are gitignored; this *.example* file is safe to commit).

# --- Compose / paths (must be explicit on a server) ---
# Keeps the runtime network named `spawnhive_spawnhive-net`, matching the constant
# the orchestrator uses to attach spawned agent containers (do not change).
COMPOSE_PROJECT_NAME=spawnhive
# Absolute HOST path used for agent bind-mounts (docker-py talks to the host daemon).
HOST_DATA_DIR=/opt/spawnhive/data

# --- Secrets (generate strong values) ---
POSTGRES_PASSWORD=CHANGE-ME-strong-db-password
MINIO_ROOT_USER=CHANGE-ME-minio-user
MINIO_ROOT_PASSWORD=CHANGE-ME-strong-minio-password
# Generate: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=CHANGE-ME-64-byte-hex
# Refuse to boot with an empty/placeholder JWT_SECRET.
REQUIRE_STRONG_SECRETS=true

# --- Public demo posture ---
# Closed signup: the committee logs in with the existing account that arrives via
# the data copy (tester@x.dev). Set true only if you want open self-registration.
ALLOW_OPEN_REGISTRATION=false
CORS_ALLOWED_ORIGINS=https://spawnhive.cloud

# --- LLM bootstrap (optional) ---
# Provider config also comes with the data copy (then gets sanitized to placeholders),
# so these can stay blank. Fill them only to seed a fresh default provider on first boot.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
