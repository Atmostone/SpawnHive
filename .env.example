# Optional LLM bootstrap. If all three are set, on first boot SpawnHive
# auto-creates a default Provider+Model in the default workspace from these
# values (see app/main.py:seed_default_provider). Otherwise add a provider
# via UI → Settings → Providers & Models.
# Endpoint must be OpenAI-compatible (litellm uses the OpenAI protocol).
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# PostgreSQL
POSTGRES_DB=spawnhive
POSTGRES_USER=spawnhive
POSTGRES_PASSWORD=password

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Auth (R1) — generate via: python -c "import secrets; print(secrets.token_hex(64))"
# REPLACE this dev-default in production deployments.
JWT_SECRET=dev-only-replace-me-with-64-byte-hex-in-production

# Deployment (SPA-78) — optional; defaults below keep local dev behavior unchanged.
# CORS: comma-separated origins the API accepts; empty = the dev localhost list.
CORS_ALLOWED_ORIGINS=
# Set false on a public deployment to disable self-service signup.
ALLOW_OPEN_REGISTRATION=true
# When true, boot refuses an empty or placeholder JWT_SECRET (leave false in dev).
REQUIRE_STRONG_SECRETS=false
