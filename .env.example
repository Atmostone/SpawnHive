# SpawnHive LLM settings (OpenAI-compatible endpoint for litellm)
LLM_BASE_URL=https://api.minimax.io/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=MiniMax-M2.7

# PostgreSQL
POSTGRES_DB=spawnhive
POSTGRES_USER=spawnhive
POSTGRES_PASSWORD=password

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Auth (R1) — generate via: python -c "import secrets; print(secrets.token_hex(64))"
# REPLACE this dev-default in production deployments.
JWT_SECRET=dev-only-replace-me-with-64-byte-hex-in-production
